{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RCF Lite Design",
  "type": "object",
  "required": ["overview", "components"],
  "properties": {
    "overview": { "type": "string", "description": "Architecture overview -- what components exist and how they connect" },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "purpose", "tracesTo"],
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "tracesTo": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Requirement IDs this component serves (e.g., REQ-001)"
          },
          "technology": { "type": "string", "description": "Key technology used (from standards)" },
          "files": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Source files that implement this component"
          }
        },
        "additionalProperties": false
      }
    },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["method", "path", "purpose", "tracesTo"],
        "properties": {
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "path": { "type": "string" },
          "purpose": { "type": "string" },
          "tracesTo": { "type": "string", "description": "Requirement ID" }
        },
        "additionalProperties": false
      }
    },
    "dataModel": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity", "fields"],
        "properties": {
          "entity": { "type": "string" },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
